{
  "installCommand": "git clone https://github.com/flutter/flutter.git -b stable --depth 1 _flutter",
  "buildCommand": "export PATH=\"$PATH:$(pwd)/_flutter/bin\" && flutter pub get && flutter build web --release",
  "outputDirectory": "build/web",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}